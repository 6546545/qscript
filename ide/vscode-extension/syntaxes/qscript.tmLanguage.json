{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "QScript",
  "scopeName": "source.qscript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#strings" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.qscript",
          "match": "//.*$"
        },
        {
          "name": "comment.block.qscript",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.qscript",
          "match": "\\b(fn|let|if|else|loop|for|while|break|continue|return|quantum)\\b"
        },
        {
          "name": "keyword.other.qscript",
          "match": "\\b(type|true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.qscript",
          "match": "\\b(unit|i32|bool)\\b"
        },
        {
          "name": "storage.type.qreg.qscript",
          "match": "\\bqreg\\s*<\\s*\\d+\\s*>"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.numeric.qscript",
          "match": "\\b(0x[0-9a-fA-F]+|0b[01]+|0o[0-7]+|\\d+)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.qscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.qscript",
              "match": "\\\\[nrt\"\\\\]"
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.qscript",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.qscript",
          "match": "<=|>=|==|!=|<|>"
        },
        {
          "name": "keyword.operator.logical.qscript",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.qscript",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.qscript",
          "match": "="
        },
        {
          "name": "punctuation.definition.bracket.qscript",
          "match": "[{}\\[\\]()<>,:;]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.qscript",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    }
  }
}
